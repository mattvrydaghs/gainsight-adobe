{
  "widgets": [
    {
      "version": "1.0.0",
      "title": "Select Community",
      "description": "A widget built with React and the Widget SDK.",
      "category": "Custom",
      "imageName": "events_calendar",
      "source": {
        "path": "widgets/report-bug/dist",
        "entry": "index.html"
      },
      "configuration": {
        "properties": [
          {
            "name": "row_size",
            "label": "Items per row",
            "description": "Number of items to display per row (1-6)",
            "type": "number",
            "defaultValue": 5,
            "rules": {
              "required": true,
              "minimum": 1,
              "maximum": 6
            }
          },
          {
            "name": "conversation_type",
            "label": "Conversation Type",
            "type": "select",
            "defaultValue": "idea",
            "options": [
              {
                "label": "Bug",
                "value": "conversation"
              },
              {
                "label": "Feature Request",
                "value": "idea"
              },
              {
                "label": "Question",
                "value": "question"
              }
            ],
            "rules": {
              "required": true
            }
          },
          {
            "name": "custom_title",
            "label": "Title",
            "type": "text",
            "defaultValue": "Select a community"
          },
          {
            "name": "custom_description",
            "label": "Description",
            "type": "text",
            "defaultValue": ""
          },
          {
            "name": "showTopicsCount",
            "label": "Show Topics Count",
            "type": "boolean",
            "defaultValue": true
          }
        ]
      },
      "defaultConfig": {
        "title": "",
        "row_size": 5,
        "conversation_type": "conversation",
        "custom_title": "Select a community",
        "custom_description": "Choose the Adobe product you'd like to report a bug for. Note that bug reporting isn't available in every community — if your product isn't listed, it may not be supported here.",
        "showTopicsCount": true
      },
      "type": "report-bug"
    }
  ]
}
