{
  "widgets": [
    {
      "version": "1.0.0",
      "title": "Report Bug",
      "description": "A widget built with React and the Widget SDK.",
      "category": "Custom",
      "imageSrc": "widgets/report-bug/thumbnail.png",
      "source": {
        "path": "widgets/report-bug/dist",
        "entry": "index.html"
      },
      "configuration": {
        "properties": [
          {
            "name": "row_size",
            "label": "Items per row",
            "type": "number",
            "defaultValue": 5,
            "rules": {
              "required": true,
              "minimum": 1,
              "maximum": 6
            }
          },
          {
            "name": "conversation_type",
            "label": "Conversation Type",
            "type": "select",
            "defaultValue": "idea",
            "options": [
              {
                "label": "Bug",
                "value": "bug"
              },
              {
                "label": "Feature Request",
                "value": "idea"
              },
              {
                "label": "Question",
                "value": "question"
              }
            ]
          }
        ]
      },
      "defaultConfig": {
        "title": "Report Bug",
        "description": "A widget built with React and the Widget SDK."
      },
      "type": "report-bug"
    }
  ]
}
