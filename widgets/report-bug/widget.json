{
  "version": "1.0.0",
  "title": "Report Bug",
  "description": "A widget built with React and the Widget SDK.",
  "category": "Custom",
  "imageSrc": "thumbnail.png",
  "source": {
    "path": "dist",
    "entry": "index.html"
  },
  "configuration": {
    "properties": [
      {
        "name": "row_size",
        "label": "Items per row",
        "description": "Number of items to display per row (1-6)",
        "type": "number",
        "defaultValue": 5,
        "rules":{
          "required": true,
          "minimum": 1,
          "maximum": 6
        }
      },
      {
        "name": "conversation_type",
        "label": "Conversation Type",
        "type": "select",
        "defaultValue": "idea",
        "options": [
          {
            "label": "Bug",
            "value": "conversation"
          },
          {
            "label": "Feature Request",
            "value": "idea"
          },
          {
            "label": "Question",
            "value": "question"
          }
        ]
      },
      {
        "name":"custom_title",
        "label":"Title",
        "type":"text",
        "defaultValue":"Select a community"
      },
      {
        "name": "custom_description",
        "label": "Description",
        "type": "text",
        "defaultValue": ""
      },
      {
        "name": "showTopicsCount",
        "label": "Show Topics Count",
        "type": "boolean",
        "defaultValue": true
      }
    ]
  },
  "defaultConfig": {
    "title": "Report Bug",
    "description": "A widget built with React and the Widget SDK."
  }
}