# Community API Configuration
# Copy this file to .env.local and fill in your credentials

# OAuth2 Token Endpoint (correct path from API_SPEC)
COMMUNITY_OAUTH_TOKEN_URL=https://api.example.com/oauth2/token

# API Base URL
COMMUNITY_API_URL=https://api.example.com/v2

# OAuth2 Client Credentials
COMMUNITY_API_CLIENT_ID=your-client-id-here
COMMUNITY_API_CLIENT_SECRET=your-client-secret-here
